# Heildepot Server Konfiguration
# Kopiere diese Datei als .env und passe die Werte an

# Server
PORT=3001
JWT_SECRET=dein-geheimes-jwt-token-hier-aendern

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=heildepot@example.com
MAIL_PASS=dein-mail-passwort
MAIL_FROM=Heildepot Freundeskreis <heildepot@example.com>

# Admin
ADMIN_EMAIL=admin@heildepot.de
ADMIN_PASS=admin-passwort-hier-aendern

# Frontend URL (fuer E-Mail-Links)
FRONTEND_URL=https://lichtungooo.github.io/heildepot-prototyp
